<UserControl x:Class="IsblCheck.Views.Panels.ReportViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:b="clr-namespace:IsblCheck.UI.Behaviors"
             xmlns:l="clr-namespace:IsblCheck.UI.Localization"
             xmlns:r="clr-namespace:IsblCheck.Core.Reports;assembly=IsblCheck.Core"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="600">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Summary Bar -->
    <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
      <StackPanel Orientation="Horizontal">
        <Border Background="#FDE7E9" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Error_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D13438">
              <TextBlock.Text>
                <l:Localization Key="COUNT_ERRORS">
                  <Binding Path="ErrorCount" Mode="OneWay"/>
                </l:Localization>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Border>
        <Border Background="#FFF8E1" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Warning_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#9D5D00">
              <TextBlock.Text>
                <l:Localization Key="COUNT_WARNINGS">
                  <Binding Path="WarningCount" Mode="OneWay"/>
                </l:Localization>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Border>
        <Border Background="#E8F4FD" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Information_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#0063B1">
              <TextBlock.Text>
                <l:Localization Key="COUNT_MESSAGES">
                  <Binding Path="InformationCount" Mode="OneWay"/>
                </l:Localization>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <!-- Filter Toolbar -->
    <Border Grid.Row="1" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
      <ToolBarTray>
        <ToolBar Background="Transparent" BorderThickness="0">
        <ToggleButton IsChecked="{Binding IsErrorsShown, Mode=TwoWay}">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Error_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" VerticalAlignment="Center">Ошибки</TextBlock>
          </StackPanel>
        </ToggleButton>
        <ToggleButton IsChecked="{Binding IsWarningsShown, Mode=TwoWay}">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Warning_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" VerticalAlignment="Center">Предупреждения</TextBlock>
          </StackPanel>
        </ToggleButton>
        <ToggleButton IsChecked="{Binding IsInformationsShown, Mode=TwoWay}">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/Information_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" VerticalAlignment="Center">Информация</TextBlock>
          </StackPanel>
        </ToggleButton>
        <Separator/>
        <Button Command="{Binding ExportAsCsvCommand, Mode=OneWay}"
                ToolTip="{l:Localization EXPORT_AS_CSV}">
          <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/CSV_20.png" Width="14" Height="14" Margin="0,0,4,0"/>
            <TextBlock FontSize="12" VerticalAlignment="Center">Экспорт CSV</TextBlock>
          </StackPanel>
        </Button>
      </ToolBar>
      </ToolBarTray>
    </Border>

    <!-- DataGrid -->
    <DataGrid Grid.Row="2"
              ItemsSource="{Binding ReportMessages, Mode=OneWay, IsAsync=True}"
              AutoGenerateColumns="False"
              Background="White"
              BorderThickness="0"
              HeadersVisibility="Column"
              HorizontalGridLinesBrush="#F0F0F0"
              VerticalGridLinesBrush="#F0F0F0"
              SelectionUnit="FullRow"
              RowHeight="28"
              EnableRowVirtualization="True" 
              CanUserResizeRows="False"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridTemplateColumn Width="32" CanUserResize="False" 
                                CanUserSort="True" SortMemberPath="Level">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" Width="16" Height="16">
                <Image.Style>
                  <Style TargetType="Image">
                    <Setter Property="Source" Value="{x:Null}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Error}">
                        <Setter Property="Source" Value="/Resources/Error_20.png"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Warning}">
                        <Setter Property="Source" Value="/Resources/Warning_20.png"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Information}">
                        <Setter Property="Source" Value="/Resources/Information_20.png"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Image.Style>
              </Image>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Код"
                            Width="70"    
                            Binding="{Binding Code, Mode=OneWay}"/>
        <DataGridTextColumn Header="Описание"
                            Width="*"
                            Binding="{Binding Description, Mode=OneWay}"/>
        <DataGridTextColumn Header="Документ"
                            Width="180"
                            Binding="{Binding Document.Name, Mode=OneWay}"/>
        <DataGridTextColumn Header="Строка"
                            Width="60"
                            Binding="{Binding Position.Line, Mode=OneWay}"/>
        <DataGridTextColumn Header="Столбец"
                            Width="60"
                            Binding="{Binding Position.Column, Mode=OneWay}"/>
      </DataGrid.Columns>
      <DataGrid.CellStyle>
        <Style TargetType="DataGridCell">
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
          <Setter Property="Padding" Value="4,2"/>
          <Setter Property="FontSize" Value="13"/>
          <Setter Property="ToolTip" 
                  Value="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"/>
        </Style>
      </DataGrid.CellStyle>
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Style.Triggers>
            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Error}">
              <Setter Property="Background" Value="#FFF0F0"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Warning}">
              <Setter Property="Background" Value="#FFFBF0"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity, Mode=OneWay}" Value="{x:Static r:Severity.Information}">
              <Setter Property="Background" Value="#F0F8FF"/>
            </DataTrigger>
          </Style.Triggers>
          <Setter Property="b:MouseDoubleClickBehavior.Command"
                  Value="{Binding DataContext.ShowReportMessageCommand,
                                  RelativeSource={RelativeSource FindAncestor, AncestorType=DataGrid},
                                  Mode=OneWay}"/>
          <Setter Property="b:MouseDoubleClickBehavior.CommandParameter"
                  Value="{Binding}"/>
          <Setter Property="b:EnterDownBehavior.Command"
                  Value="{Binding DataContext.ShowReportMessageCommand,
                                  RelativeSource={RelativeSource FindAncestor, AncestorType=DataGrid},
                                  Mode=OneWay}"/>
          <Setter Property="b:EnterDownBehavior.CommandParameter"
                  Value="{Binding}"/>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </Grid>
</UserControl>
